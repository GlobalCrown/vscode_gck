	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"string.comment"
			],
			"settings": {
				"foreground": "#6B7D8F"
			}
		},
		{
			"scope": [
				"constant.other.placeholder",
				"constant.character"
			],
			"settings": {
				"foreground": "#C72E0F"
			}
		},
		{
			"scope": [
				"constant",
				"entity.name.constant",
				"variable.other.constant",
				"variable.other.enummember",
				"variable.language",
				"entity"
			],
			"settings": {
				"foreground": "#1B4F8A"
			}
		},
		{
			"scope": [
				"entity.name",
				"meta.export.default",
				"meta.definition.variable"
			],
			"settings": {
				"foreground": "#8B5C00"
			}
		},
		{
			"scope": [
				"variable.parameter.function",
				"meta.jsx.children",
				"meta.block",
				"meta.tag.attributes",
				"entity.name.constant",
				"meta.object.member",
				"meta.embedded.expression"
			],
			"settings": {
				"foreground": "#1F2328"
			}
		},
		{
			"scope": "entity.name.function",
			"settings": {
				"foreground": "#6D4CAF"
			}
		},
		{
			"scope": [
				"entity.name.tag",
				"support.class.component"
			],
			"settings": {
				"foreground": "#4E8E2E"
			}
		},
		{
			"scope": "keyword",
			"settings": {
				"foreground": "#2569B0"
			}
		},
		{
			"scope": [
				"storage",
				"storage.type"
			],
			"settings": {
				"foreground": "#2569B0"
			}
		},
		{
			"scope": [
				"storage.modifier.package",
				"storage.modifier.import",
				"storage.type.java"
			],
			"settings": {
				"foreground": "#1F2328"
			}
		},
		{
			"scope": [
				"string",
				"string punctuation.section.embedded source"
			],
			"settings": {
				"foreground": "#4E8E2E"
			}
		},
		{
			"scope": "support",
			"settings": {
				"foreground": "#1B4F8A"
			}
		},
		{
			"scope": "meta.property-name",
			"settings": {
				"foreground": "#1B4F8A"
			}
		},
		{
			"scope": "variable",
			"settings": {
				"foreground": "#8B5C00"
			}
		},
		{
			"scope": "variable.other",
			"settings": {
				"foreground": "#1F2328"
			}
		},
		{
			"scope": "invalid.broken",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#C72E0F"
			}
		},
		{
			"scope": "invalid.deprecated",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#C72E0F"
			}
		},
		{
			"scope": "invalid.illegal",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#C72E0F"
			}
		},
		{
			"scope": "invalid.unimplemented",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#C72E0F"
			}
		},
		{
			"scope": "message.error",
			"settings": {
				"foreground": "#C72E0F"
			}
		},
		{
			"scope": "string variable",
			"settings": {
				"foreground": "#1B4F8A"
			}
		},
		{
			"scope": [
				"source.regexp",
				"string.regexp"
			],
			"settings": {
				"foreground": "#1B4F8A"
			}
		},
		{
			"scope": "support.constant",
			"settings": {
				"foreground": "#1B4F8A"
			}
		},
		{
			"scope": "support.variable",
			"settings": {
				"foreground": "#1B4F8A"
			}
		},
		{
			"scope": "support.type.property-name.json",
			"settings": {
				"foreground": "#2569B0"
			}
		},
		{
			"scope": "punctuation.separator",
			"settings": {
				"foreground": "#6B7D8F"
			}
		},
		{
			"scope": "punctuation.definition.tag",
			"settings": {
				"foreground": "#4E8E2E"
			}
		},
		{
			"scope": "punctuation.definition.string",
			"settings": {
				"foreground": "#4E8E2E"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"support.constant",
				"constant.character",
				"constant.escape",
				"keyword.other.unit"
			],
			"settings": {
				"foreground": "#1B4F8A"
			}
		},
		{
			"scope": "markup.heading",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#2569B0"
			}
		},
		{
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#4E8E2E"
			}
		},
		{
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#C72E0F"
			}
		},
		{
			"scope": "markup.changed",
			"settings": {
				"foreground": "#2569B0"
			}
		},
		{
			"scope": "markup.inline.raw",
			"settings": {
				"foreground": "#1B4F8A"
			}
		}
	]
}
